{
  "manifest_version": 3,
  "name": "Ticket Link Copier",
  "version": "1.1",
  "description": "Copy Jira/GitHub ticket titles as links with Cmd+C",
  "permissions": ["clipboardWrite"],
  "content_scripts": [
    {
      "matches": ["https://*.atlassian.net/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "48": "icon.png"
  }
}
